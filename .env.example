# Copy to .env for local configuration. NEVER commit a real .env (it is gitignored).
# In production these are set as Netlify environment variables.

# --- Creative generation (OpenAI gpt-image-2) ---

# OpenAI API key. Required for the "Laat AI ontwerpen" tab. Without it the tab
# returns a friendly error (no crash). OPENAI_API_KEY is the canonical name;
# OPENAI_KEY is also accepted for backwards compatibility.
OPENAI_API_KEY=

# Optional overrides:
# OPENAI_IMAGE_MODEL=gpt-image-2   # the image model
# OPENAI_IMAGE_SIZE=1024x1440      # portrait, ~A0 (1:1.406). Standard 1024x1536 (1:1.5) also works.
#                                  # A larger size sharpens print at higher cost/latency.
# OPENAI_IMAGE_QUALITY=medium      # low | medium | high
# AI_VARIANTS=2                    # backgrounds per click (1-4). Each is a separate image = that many x cost.
# OPENAI_DEBUG=1                   # log generation failures server-side (never the key)

# NOTE: generation is slow (~50-70s), so it runs in a Netlify *background*
# function that writes results to Netlify Blobs; creative-status polls the store.
# No extra config needed for Blobs on Netlify.

# --- Legacy (not used by the current app) ---
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
# APP_URL="MY_APP_URL"
