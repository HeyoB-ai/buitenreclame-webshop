# Copy to .env for local configuration. NEVER commit a real .env (it is gitignored).
# In production these are set as Netlify environment variables.

# --- Creative generation (Higgsfield) ---

# Mode: "mock" (default — no external calls, no credits) or "live" (calls
# Higgsfield). Without both keys below, the app stays on mock even if set to live.
HF_MODE=mock

# Higgsfield API credentials — the KEY:SECRET pair. Leave empty for mock mode.
HF_API_KEY=
HF_API_SECRET=

# Higgsfield model_id (POST https://platform.higgsfield.ai/{model_id}).
# Default = proven-working Soul. Nano Banana is not on the public REST API yet.
HF_IMAGE_MODEL=higgsfield-ai/soul/standard

# Optional overrides:
# HF_IMAGE_RESOLUTION=1080p   # model-dependent (Soul: 720p/1080p)
# HF_DEBUG=1                  # log live-generation failures server-side (off by default)

# Backgrounds per "genereren" click = one parallel job each = that many x credits.
# Default 2. The account allows only 4 concurrent requests, so 3+ fills the queue
# and slows a run down (measured >120s at 3). Clamped to 4. Raise once the plan's
# concurrency is scaled up.
# HF_VARIANTS=2

# --- Legacy (AI Studio scaffold; not used by the current app) ---
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
# APP_URL="MY_APP_URL"
